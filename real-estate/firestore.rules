rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Properties: anyone can read, nobody can write from client
    match /properties/{id} {
      allow read: if true;
      allow write: if false;
    }

    // Config (hero): anyone can read, nobody can write from client
    match /config/{id} {
      allow read: if true;
      allow write: if false;
    }
  }
}
